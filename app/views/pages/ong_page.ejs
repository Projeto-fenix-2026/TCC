<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ong</title>
    <link rel="stylesheet" href="css/ong_page.css">
</head>

<body>
      <%- include('../partials/header2.ejs') %>
    <main>
        <nav class="profile-card shadow-sm">
            <!-- Foto -->
            <% if (ong.imagem) { %>
                <img src="<%= ong.imagem %>" alt="<%= ong.nome %>" class="avatar">
            <% } else { %>
                <div class="avatar card-sem-imagem"></div>
            <% } %>

            <!-- Nome -->
            <nav class="info-item">
                <i class="bi bi-person"></i>
                <section class="info-text">
                    <strong>Nome</strong>
                    <span><%= ong.nome %></span>
                </section>
            </nav>

            <!-- Sobre -->
            <nav class="info-item">
                <i class="bi bi-info-circle"></i>
                <section class="info-text">
                    <strong>Descrição</strong>
                    <span><%= ong.descricao || "Sem descrição." %></span>
                </section>
            </nav>

            <!-- Telefone -->
            <nav class="info-item">
                <i class="bi bi-telephone"></i>
                <section class="info-text">
                    <strong>Telefone</strong>
                    <span><%= ong.telefone %></span>
                </section>
            </nav>

            <!-- Email -->
            <nav class="info-item">
                <i class="bi bi-envelope"></i>
                <section class="info-text">
                    <strong>Email</strong>
                    <span><%= ong.email %></span>
                </section>
            </nav>  

            <!-- ONG -->
            <nav class="info-item">
                <i class="bi bi-hospital"></i>
                <section class="info-text">
                    
                    
                    <button class="button-contato">Entrar em contato</button>
            </nav>
        </nav>
        

    </main>
     <%- include('../partials/footer.ejs') %>
     <script src="../js/text.js"></script>

</body>

</html>