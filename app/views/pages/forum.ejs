<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fórum — Fênix</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link rel="stylesheet" href="../css/forum.css" />
</head>
<body>

<%- include('../partials/header2.ejs') %>

<div class="forum-layout">

  <!-- ── LEFT SIDEBAR ── -->
  <nav class="sidebar-left" aria-label="Categorias do fórum">
    <section class="sidebar-card">
      <header class="sidebar-card-header">Categorias</header>
      <a class="nav-item active" href="#">
        <span class="nav-icon"><span class="icon">home</span></span> Todos os tópicos
      </a>
      <a class="nav-item" href="#">
        <span class="nav-icon"><span class="icon">crisis_alert</span></span> Violência Doméstica
      </a>
      <a class="nav-item" href="#">
        <span class="nav-icon"><span class="icon">gavel</span></span> Direitos da Mulher
      </a>
      <a class="nav-item" href="#">
        <span class="nav-icon"><span class="icon">handshake</span></span> Buscar Apoio
      </a>
      <a class="nav-item" href="#">
        <span class="nav-icon"><span class="icon">forum</span></span> Relatos
      </a>
      <a class="nav-item" href="#">
        <span class="nav-icon"><span class="icon">psychology</span></span> Saúde Mental
      </a>
      <a class="nav-item" href="#">
        <span class="nav-icon"><span class="icon">business</span></span> ONGs
      </a>
    </section>
  </nav>

  <!-- ── MAIN FEED ── -->
  <main class="feed">
    <header class="feed-header">
      <h1 class="feed-title">
        <span class="icon icon-lg" style="color:var(--primary);">favorite</span>
        Fórum Fênix
      </h1>
      <button class="btn-nova-post">
        <span class="icon icon-sm">edit</span> Nova publicação
      </button>
    </header>

    <nav class="feed-controls" aria-label="Ordenar publicações">
      <button class="sort-btn active">
        <span class="icon icon-sm">local_fire_department</span> Em alta
      </button>
      <button class="sort-btn">
        <span class="icon icon-sm">schedule</span> Recentes
      </button>
      <button class="sort-btn">
        <span class="icon icon-sm">chat_bubble</span> Mais comentados
      </button>
    </nav>

    <!-- POST 1 -->
    <article class="post-card">
      <div class="post-inner">
        <section class="vote-col">
          <button class="vote-btn up" onclick="vote(event,this,'up')"><span class="icon">keyboard_arrow_up</span></button>
          <span class="vote-count">245</span>
          <button class="vote-btn down" onclick="vote(event,this,'down')"><span class="icon">keyboard_arrow_down</span></button>
        </section>
        <section class="post-body">
          <header class="post-meta">
            <a class="post-category" href="#"><span class="icon">crisis_alert</span> Violência Doméstica</a>
            <span class="meta-sep">•</span>
            <span class="post-author">por usuária anônima</span>
            <span class="meta-sep">•</span>
            <time class="post-time">há 2 horas</time>
          </header>
          <span class="post-flair">Dúvida</span>
          <h2 class="post-title">Como denunciar violência doméstica com segurança e em sigilo?</h2>
          <p class="post-excerpt">Estou numa situação difícil e tenho medo de fazer a denúncia. Quero saber quais canais são mais seguros e se minha identidade fica protegida...</p>
          <footer class="post-actions">
            <button class="action-btn"><span class="icon">chat_bubble</span> 67 Comentários</button>
            <button class="action-btn"><span class="icon">share</span> Compartilhar</button>
            <button class="action-btn"><span class="icon">bookmark</span> Salvar</button>
          </footer>
        </section>
      </div>
    </article>

    <!-- POST 2 -->
    <article class="post-card">
      <div class="post-inner">
        <section class="vote-col">
          <button class="vote-btn up" onclick="vote(event,this,'up')"><span class="icon">keyboard_arrow_up</span></button>
          <span class="vote-count">1,2 mil</span>
          <button class="vote-btn down" onclick="vote(event,this,'down')"><span class="icon">keyboard_arrow_down</span></button>
        </section>
        <section class="post-body">
          <header class="post-meta">
            <a class="post-category" href="#"><span class="icon">forum</span> Relatos</a>
            <span class="meta-sep">•</span>
            <span class="post-author">por Maria S.</span>
            <span class="meta-sep">•</span>
            <time class="post-time">há 1 dia</time>
          </header>
          <span class="post-flair">Relato</span>
          <h2 class="post-title">Consegui sair de uma situação de abuso com apoio de uma ONG — minha história</h2>
          <p class="post-excerpt">Quero compartilhar minha história para dar esperança a outras mulheres. Depois de 3 anos, encontrei apoio no projeto Recomeçar e hoje tenho uma nova vida...</p>
          <footer class="post-actions">
            <button class="action-btn"><span class="icon">chat_bubble</span> 134 Comentários</button>
            <button class="action-btn"><span class="icon">share</span> Compartilhar</button>
            <button class="action-btn"><span class="icon">bookmark</span> Salvar</button>
          </footer>
        </section>
      </div>
    </article>

    <!-- POST 3 -->
    <article class="post-card">
      <div class="post-inner">
        <section class="vote-col">
          <button class="vote-btn up" onclick="vote(event,this,'up')"><span class="icon">keyboard_arrow_up</span></button>
          <span class="vote-count">89</span>
          <button class="vote-btn down" onclick="vote(event,this,'down')"><span class="icon">keyboard_arrow_down</span></button>
        </section>
        <section class="post-body">
          <header class="post-meta">
            <a class="post-category" href="#"><span class="icon">gavel</span> Direitos da Mulher</a>
            <span class="meta-sep">•</span>
            <span class="post-author">por Ana Lima</span>
            <span class="meta-sep">•</span>
            <time class="post-time">há 3 dias</time>
          </header>
          <span class="post-flair">Informação</span>
          <h2 class="post-title">Quais são meus direitos ao registrar um boletim de ocorrência por violência doméstica?</h2>
          <p class="post-excerpt">Muitas mulheres não sabem que têm direito a medidas protetivas imediatas, atendimento preferencial e acompanhamento especializado...</p>
          <footer class="post-actions">
            <button class="action-btn"><span class="icon">chat_bubble</span> 45 Comentários</button>
            <button class="action-btn"><span class="icon">share</span> Compartilhar</button>
            <button class="action-btn"><span class="icon">bookmark</span> Salvar</button>
          </footer>
        </section>
      </div>
    </article>

    <!-- POST 4 -->
    <article class="post-card">
      <div class="post-inner">
        <section class="vote-col">
          <button class="vote-btn up" onclick="vote(event,this,'up')"><span class="icon">keyboard_arrow_up</span></button>
          <span class="vote-count">312</span>
          <button class="vote-btn down" onclick="vote(event,this,'down')"><span class="icon">keyboard_arrow_down</span></button>
        </section>
        <section class="post-body">
          <header class="post-meta">
            <a class="post-category" href="#"><span class="icon">psychology</span> Saúde Mental</a>
            <span class="meta-sep">•</span>
            <span class="post-author">por equipe Fênix</span>
            <span class="meta-sep">•</span>
            <time class="post-time">há 5 dias</time>
          </header>
          <span class="post-flair">Recurso</span>
          <h2 class="post-title">Lista de serviços gratuitos de saúde mental para mulheres em situação de vulnerabilidade</h2>
          <p class="post-excerpt">Compilamos uma lista com CVV, CAPS, CRAS e outros serviços totalmente gratuitos disponíveis em todo o Brasil. Nenhuma mulher precisa passar por isso sozinha...</p>
          <footer class="post-actions">
            <button class="action-btn"><span class="icon">chat_bubble</span> 28 Comentários</button>
            <button class="action-btn"><span class="icon">share</span> Compartilhar</button>
            <button class="action-btn"><span class="icon">bookmark</span> Salvar</button>
          </footer>
        </section>
      </div>
    </article>

    <!-- POST 5 -->
    <article class="post-card">
      <div class="post-inner">
        <section class="vote-col">
          <button class="vote-btn up" onclick="vote(event,this,'up')"><span class="icon">keyboard_arrow_up</span></button>
          <span class="vote-count">57</span>
          <button class="vote-btn down" onclick="vote(event,this,'down')"><span class="icon">keyboard_arrow_down</span></button>
        </section>
        <section class="post-body">
          <header class="post-meta">
            <a class="post-category" href="#"><span class="icon">handshake</span> Buscar Apoio</a>
            <span class="meta-sep">•</span>
            <span class="post-author">por usuária anônima</span>
            <span class="meta-sep">•</span>
            <time class="post-time">há 6 dias</time>
          </header>
          <span class="post-flair">Pergunta</span>
          <h2 class="post-title">Existe alguma casa de acolhimento em Recife para mulheres com filhos pequenos?</h2>
          <p class="post-excerpt">Preciso de ajuda urgente. Tenho dois filhos e não tenho para onde ir. Alguém conhece alguma ONG ou abrigo na região metropolitana do Recife?</p>
          <footer class="post-actions">
            <button class="action-btn"><span class="icon">chat_bubble</span> 39 Comentários</button>
            <button class="action-btn"><span class="icon">share</span> Compartilhar</button>
            <button class="action-btn"><span class="icon">bookmark</span> Salvar</button>
          </footer>
        </section>
      </div>
    </article>
  </main>

  <!-- ── RIGHT SIDEBAR ── -->
  <aside class="sidebar-right" aria-label="Informações do fórum">

    <section class="widget">
      <header class="widget-header">
        <span class="icon icon-sm">sos</span> Contatos de Emergência
      </header>
      <section class="widget-body">
        <article class="emergency-item">
          <span class="emergency-icon"><span class="icon">phone</span></span>
          <section>
            <p class="emergency-name">Ligue 180</p>
            <p class="emergency-number">Central de Atendimento à Mulher — gratuito 24h</p>
          </section>
        </article>
        <article class="emergency-item">
          <span class="emergency-icon"><span class="icon">local_police</span></span>
          <section>
            <p class="emergency-name">Polícia Militar</p>
            <p class="emergency-number">190 — emergências imediatas</p>
          </section>
        </article>
        <article class="emergency-item">
          <span class="emergency-icon"><span class="icon">support_agent</span></span>
          <section>
            <p class="emergency-name">CVV</p>
            <p class="emergency-number">188 — apoio emocional 24h</p>
          </section>
        </article>
        <article class="emergency-item">
          <span class="emergency-icon"><span class="icon">local_hospital</span></span>
          <section>
            <p class="emergency-name">SAMU</p>
            <p class="emergency-number">192 — urgências médicas</p>
          </section>
        </article>
      </section>
    </section>

    <section class="widget">
      <header class="widget-header">
        <span class="icon icon-sm">checklist</span> Regras do Fórum
      </header>
      <section class="widget-body">
        <p class="rule-item"><span class="rule-num">1.</span> Respeite todas as participantes</p>
        <p class="rule-item"><span class="rule-num">2.</span> Não compartilhe dados pessoais de terceiros</p>
        <p class="rule-item"><span class="rule-num">3.</span> Publicações anônimas são permitidas</p>
        <p class="rule-item"><span class="rule-num">4.</span> Evite julgamentos — este é um espaço seguro</p>
        <p class="rule-item"><span class="rule-num">5.</span> Denuncie conteúdos inadequados</p>
      </section>
    </section>

    <section class="widget">
      <header class="widget-header">
        <span class="icon icon-sm">link</span> Links Úteis
      </header>
      <section class="widget-body">
        <p class="rule-item"><a href="/ongs"><span class="icon icon-sm">business</span> Encontre uma ONG</a></p>
        <p class="rule-item"><a href="/direitos"><span class="icon icon-sm">gavel</span> Seus Direitos</a></p>
        <p class="rule-item"><a href="/geolocalizacao"><span class="icon icon-sm">location_on</span> Geolocalização</a></p>
        <p class="rule-item"><a href="/sobre_nos"><span class="icon icon-sm">info</span> Sobre o Fênix</a></p>
      </section>
    </section>

    <footer class="forum-footer">
      Fênix — Reerguendo Mulheres &nbsp;·&nbsp; 2026<br>
      <a href="/sobre_nos">Sobre nós</a> &nbsp;·&nbsp;
      <a href="/contato">Contato</a>
    </footer>

  </aside>

</div>

<script src="../js/forum.js"></script>
<script src="../js/text.js"></script>
<%- include('../partials/footer.ejs') %>
</body>
</html>
