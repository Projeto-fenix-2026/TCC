<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lykmapipo/themify-icons@0.1.2/css/themify-icons.css">
    <link rel="stylesheet" href="../css/index-adm.css">


</head>

<body>
    <input type="checkbox" id="sidebare-toggle">
    <section class="sidebar">
        <section class="sidebar-header">
            <h3 class="brand"><span class="ti-unlink"></span>
                <span>Fenix</span>
            </h3>
            <label for="sidebare-toggle" class="ti-menu-alt"></label>
        </section>

        <section class="sidebar-menu">
            <ul>
                <li>
                    <a href="#">
                        <span class="ti-home"></span>
                        <span>Home</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-face-smile"></span>
                        <span>Team</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-agenda"></span>
                        <span>Tasks</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-clipboard"></span>
                        <span>Leaves</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-folder"></span>
                        <span>Projects</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-time"></span>
                        <span>Timesheeet</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-book"></span>
                        <span>Contacts</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="ti-settings"></span>
                        <span>Account</span>
                    </a>
                </li>


            </ul>
        </section>
    </section>


    <section class="main-content">

        <header>
            <section class="search-wrapper">
                <span class="ti-search"></span>
                <input type="search" placeholder="Search">
            </section>

            <section class="social-icons">
                <span class="ti-bell"></span>
                <span class="ti-comment"></span>
                <section></section>
            </section>
        </header>

        <main>
            <h2 class="dash-title">Overview</h2>

            <section class="dash-cards">
                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-briefcase"></span>
                        <section>
                            <h5>Account Balance</h5>
                            <h4>230</h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="#">View all</a>
                    </section>
                </section>

                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-reload"></span>
                        <section>
                            <h5>Pending</h5>
                            <h4>20</h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="#">View all</a>
                    </section>
                </section>

                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-check-box"></span>
                        <section>
                            <h5>processed</h5>
                            <h4>185</h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="#">View all</a>
                    </section>
                </section>
            </section>


            <section class="recent">
                <section class="activity-grid">
                    <section class="activity-card">
                        <h3>Recent Activity</h3>

                        <section class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Project</th>
                                        <th>Start Date</th>
                                        <th>End Date</th>
                                        <th>Team</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>App Development</td>
                                        <td>15 Aug, 2020</td>
                                        <td>22 Aug, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td>
                                            <span class="badge
                                            success">Success</span>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Logo Design</td>
                                        <td>15 Aug, 2020</td>
                                        <td>22 Aug, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td>
                                            <span class="badge
                                            warning">Processing</span>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Server setup</td>
                                        <td>15 Aug, 2020</td>
                                        <td>22 Aug, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td>
                                            <span class="badge
                                            success">Success</span>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Front-End design</td>
                                        <td>15 Aug, 2020</td>
                                        <td>22 Aug, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td>
                                            <span class="badge
                                            warning">Processing</span>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Web Development</td>
                                        <td>15 Aug, 2020</td>
                                        <td>22 Aug, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td>
                                            <span class="badge
                                            success">Success</span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </section>


                    </section>

                    <section class="summary">
                        <section class="summary-card">
                            <section class="summary-single">
                                <span class="ti-id-badge"></span>
                                <section>
                                    <h5>196</h5>
                                    <small>Number of staff</small>
                                </section>
                            </section>

                            <section class="summary-single">
                                <span class="ti-calendar"></span>
                                <section>
                                    <h5>16</h5>
                                    <small>Number of leave</small>
                                </section>
                            </section>

                            <section class="summary-single">
                                <span class="ti-face-smile"></span>
                                <section>
                                    <h5>11</h5>
                                    <small>Profile update request</small>
                                </section>
                            </section>

                        </section>

                        <section class="bday-card">
                            <section class="bday-flex">
                                <section class="bday-img"></section>
                                <section class="bday-info">
                                    <h5>Jessica</h5>
                                    <small>Birthday today</small>
                                </section>
                            </section>

                            <section class="text-center">
                                <button>
                                    <span class="ti-gift"></span>
                                    Wish him
                                </button>
                            </section>

                        </section>

                    </section>

                </section>

            </section>

        </main>

    </section>
</body>

</html>