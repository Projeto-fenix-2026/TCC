<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lykmapipo/themify-icons@0.1.2/css/themify-icons.css">
    <link rel="stylesheet" href="../css/index-adm.css">


</head>

<body>
    <input type="checkbox" id="sidebare-toggle">
    <section class="sidebar">
        <section class="sidebar-header">
            <h3 class="brand">
                <img src="../imgs/logo.png" alt="Logo Fênix" class="sidebar-logo">
                <span>Fenix</span>
            </h3>
            <label for="sidebare-toggle" class="ti-menu-alt"></label>
        </section>

        <section class="sidebar-menu">
            <ul>
                <li>
                    <a href="/adm">
                        <span class="ti-home"></span>
                        <span>Início</span>
                    </a>
                </li>
                <li>
                    <a href="/adm/adm-cliente">
                        <span class="ti-face-smile"></span>
                        <span>Usuários</span>
                    </a>
                </li>
                <li>
                    <a href="/adm/adm-ong">
                        <span class="ti-world"></span>
                        <span>ONGs</span>
                    </a>
                </li>
            </ul>
        </section>
    </section>


    <section class="main-content">

        <header>
            <section class="search-wrapper">
                <span class="ti-search"></span>
                <input type="search" placeholder="Buscar">
            </section>

            <section class="social-icons">
                <span class="ti-bell"></span>
                <span class="ti-comment"></span>
                <section></section>
            </section>
        </header>

        <main>
            <h2 class="dash-title">Visão Geral</h2>

            <section class="dash-cards">
                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-id-badge"></span>
                        <section>
                            <h5>Usuários cadastrados</h5>
                            <h4><%= totalUsuarios %></h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="/adm/adm-cliente">Ver todos</a>
                    </section>
                </section>

                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-world"></span>
                        <section>
                            <h5>ONGs cadastradas</h5>
                            <h4><%= totalOngs %></h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="/adm/adm-ong">Ver todas</a>
                    </section>
                </section>

                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-image"></span>
                        <section>
                            <h5>Perfis sem foto</h5>
                            <h4><%= semFoto %></h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="/adm/adm-cliente">Ver usuários</a>
                    </section>
                </section>
            </section>


            <section class="recent">
                <section class="activity-grid">
                    <section class="activity-card">
                        <h3>Usuários Recentes</h3>

                        <section class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Nome</th>
                                        <th>E-mail</th>
                                        <th>Gênero</th>
                                        <th>Telefone</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (recentes.length === 0) { %>
                                        <tr>
                                            <td colspan="4" style="text-align:center;">Nenhum usuário cadastrado.</td>
                                        </tr>
                                    <% } else { %>
                                        <% recentes.forEach(function(u) { %>
                                            <tr>
                                                <td><%= u.nome %></td>
                                                <td><%= u.email %></td>
                                                <td><%= u.genero || '—' %></td>
                                                <td><%= u.telefone || '—' %></td>
                                            </tr>
                                        <% }); %>
                                    <% } %>
                                </tbody>
                            </table>
                        </section>

                    </section>

                    <section class="summary">
                        <section class="summary-card">
                            <section class="summary-single">
                                <span class="ti-id-badge"></span>
                                <section>
                                    <h5><%= totalUsuarios %></h5>
                                    <small>Usuários cadastrados</small>
                                </section>
                            </section>

                            <section class="summary-single">
                                <span class="ti-world"></span>
                                <section>
                                    <h5><%= totalOngs %></h5>
                                    <small>ONGs cadastradas</small>
                                </section>
                            </section>

                            <section class="summary-single">
                                <span class="ti-image"></span>
                                <section>
                                    <h5><%= semFoto %></h5>
                                    <small>Perfis sem foto</small>
                                </section>
                            </section>
                        </section>
                    </section>

                </section>

            </section>

        </main>

    </section>
</body>

</html>