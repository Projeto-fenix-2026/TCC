<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lykmapipo/themify-icons@0.1.2/css/themify-icons.css">
    <link rel="stylesheet" href="../css/index-adm.css">


</head>

<body>
    <input type="checkbox" id="sidebare-toggle">
    <section class="sidebar">
        <section class="sidebar-header">
            <h3 class="brand"><span class="ti-unlink"></span>
                <span>Fenix</span>
            </h3>
            <label for="sidebare-toggle" class="ti-menu-alt"></label>
        </section>

        <section class="sidebar-menu">
            <ul>
                <li>
                    <a href="/adm">
                        <span class="ti-home"></span>
                        <span>Início</span>
                    </a>
                </li>
                <li>
                    <a href="/adm/adm-cliente">
                        <span class="ti-face-smile"></span>
                        <span>Usuários</span>
                    </a>
                </li>
            </ul>
        </section>
    </section>


    <section class="main-content">

        <header>
            <section class="search-wrapper">
                <span class="ti-search"></span>
                <input type="search" placeholder="Buscar">
            </section>

            <section class="social-icons">
                <span class="ti-bell"></span>
                <span class="ti-comment"></span>
                <section></section>
            </section>
        </header>

        <main>
            <h2 class="dash-title">Visão Geral</h2>

            <section class="dash-cards">
                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-briefcase"></span>
                        <section>
                            <h5>Saldo em Conta</h5>
                            <h4>230</h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="#">Ver tudo</a>
                    </section>
                </section>

                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-reload"></span>
                        <section>
                            <h5>Pendentes</h5>
                            <h4>20</h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="#">Ver tudo</a>
                    </section>
                </section>

                <section class="card-single">
                    <section class="card-body">
                        <span class="ti-check-box"></span>
                        <section>
                            <h5>Processados</h5>
                            <h4>185</h4>
                        </section>
                    </section>
                    <section class="card-footer">
                        <a href="#">Ver tudo</a>
                    </section>
                </section>
            </section>


            <section class="recent">
                <section class="activity-grid">
                    <section class="activity-card">
                        <h3>Atividade Recente</h3>

                        <section class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Projeto</th>
                                        <th>Data Início</th>
                                        <th>Data Fim</th>
                                        <th>Equipe</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Desenvolvimento do App</td>
                                        <td>15 Ago, 2020</td>
                                        <td>22 Ago, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td><span class="badge success">Concluído</span></td>
                                    </tr>
                                    <tr>
                                        <td>Design do Logo</td>
                                        <td>15 Ago, 2020</td>
                                        <td>22 Ago, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td><span class="badge warning">Em andamento</span></td>
                                    </tr>
                                    <tr>
                                        <td>Configuração do Servidor</td>
                                        <td>15 Ago, 2020</td>
                                        <td>22 Ago, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td><span class="badge success">Concluído</span></td>
                                    </tr>
                                    <tr>
                                        <td>Design Front-End</td>
                                        <td>15 Ago, 2020</td>
                                        <td>22 Ago, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td><span class="badge warning">Em andamento</span></td>
                                    </tr>
                                    <tr>
                                        <td>Desenvolvimento Web</td>
                                        <td>15 Ago, 2020</td>
                                        <td>22 Ago, 2020</td>
                                        <td class="td-team">
                                            <section class="img-1"></section>
                                            <section class="img-2"></section>
                                            <section class="img-3"></section>
                                        </td>
                                        <td><span class="badge success">Concluído</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </section>

                    </section>

                    <section class="summary">
                        <section class="summary-card">
                            <section class="summary-single">
                                <span class="ti-id-badge"></span>
                                <section>
                                    <h5>196</h5>
                                    <small>Número de usuários</small>
                                </section>
                            </section>

                            <section class="summary-single">
                                <span class="ti-calendar"></span>
                                <section>
                                    <h5>16</h5>
                                    <small>Ausências</small>
                                </section>
                            </section>

                            <section class="summary-single">
                                <span class="ti-face-smile"></span>
                                <section>
                                    <h5>11</h5>
                                    <small>Atualizações de perfil</small>
                                </section>
                            </section>
                        </section>

                        <section class="bday-card">
                            <section class="bday-flex">
                                <section class="bday-img"></section>
                                <section class="bday-info">
                                    <h5>Jessica</h5>
                                    <small>Aniversário hoje</small>
                                </section>
                            </section>

                            <section class="text-center">
                                <button>
                                    <span class="ti-gift"></span>
                                    Parabenizar
                                </button>
                            </section>
                        </section>

                    </section>

                </section>

            </section>

        </main>

    </section>
</body>

</html>