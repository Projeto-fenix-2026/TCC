<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Área de Segurança - Projeto Fênix</title>
    <link rel="stylesheet" href="/css/geolocalizacao.css" />
  </head>

  <body>
    <main class="header-seguranca">
      <h1 class="logo-titulo">Painel de Proteção Fênix</h1>
      <p class="status-conexao" id="status-texto">
        Iniciando rastreamento seguro...
      </p>
    </main>

    <main class="container-seguranca">
      <section class="mapa-wrapper">
        <header class="mapa-header">
          <h2>Sua Localização em Tempo Real</h2>
        </header>
        <iframe
          id="mapa-google"
          src=""
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </section>

      <section class="contatos-wrapper">
        <header class="contatos-header">
          <h2>Canais de Ajuda Rápida</h2>
          <p>
            Clique em um dos contatos abaixo para enviar sua localização
            atualizada imediatamente.
          </p>
        </header>

        <nav class="lista-contatos">
          <article class="card-contato emergência">
            <h3>Central de Polícia (190)</h3>
            <p>Para situações de risco iminente.</p>
            <button class="btn-emergencia" onclick="enviarAlerta('190')">
              Discar 190
            </button>
          </article>

          <article class="card-contato">
            <h3>Central de Atendimento (Ligue 180)</h3>
            <p>Orientação e denúncias de violência.</p>
            <button class="btn-alerta" onclick="enviarAlerta('5511999999999')">
              Enviar para Ligue 180
            </button>
          </article>

          <article class="card-contato">
            <h3>ONG Parceira de Apoio</h3>
            <p>Suporte jurídico e acolhimento psicológico.</p>
            <button class="btn-alerta" onclick="enviarAlerta('5511988888888')">
              Acionar Guardiã ONG
            </button>
          </article>
        </nav>
      </section>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script src="../js/geolocalizacao.js"></script>
  </body>
</html>
